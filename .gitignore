# ===========================================
# Obsidian Vault Gitignore
# ===========================================

# Obsidian 配置（设备特定，不需要版本控制）
.obsidian/
.obsidian

# 回收站
.trash/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时文件
*.tmp
*.log
*~

# 大型媒体文件夹（Pr/Ae/C4d 图片视频不上传）
Pr/
Ae/
C4D/

# 仅追踪笔记文件
*.md
!.gitignore
